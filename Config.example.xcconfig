// Copy this file to Config.xcconfig and fill in real values.
// Config.xcconfig is gitignored — keep secrets out of git.

SUPABASE_URL = https:/$()/your-project.supabase.co
SUPABASE_ANON_KEY = your-publishable-key-here

// Apple Developer Team ID — required for Sign in with Apple.
// Find it at developer.apple.com/account → Membership.
DEVELOPMENT_TEAM =
